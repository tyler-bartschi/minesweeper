{
  "name": "minesweeper-shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "test": "jest --passWithNoTests"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  },
  "jest": {
    "verbose": true,
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "\\.(css|less)$": "<rootDir>/test/__mocks__/styleMock.js"
    },
    "testMatch": [
      "<rootDir>/test/**/*.test.tsx",
      "<rootDir>/test/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest",
      "\\.js$": "babel-jest"
    }
  }
}
